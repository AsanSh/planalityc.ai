# ============================================================================
# API server — пример переменных окружения.
# Скопируйте в `.env` и заполните значениями. Файл `.env` в git НЕ коммитится.
#
# Переезд на свой сервер (Hetzner) + домен:
#   - DATABASE_URL    → строка подключения к вашему Postgres
#   - ALLOWED_ORIGINS → домен фронта, напр. https://app.your-domain.kz
#   - FRONTEND_URL / APP_URL / API_PUBLIC_URL → ваши новые URL
#   - переменные VERCEL_* на своём сервере не нужны (их выставляет Vercel)
# ============================================================================

# --- Окружение ---
NODE_ENV=production               # development | production
LOG_LEVEL=info                    # trace|debug|info|warn|error

# --- База данных (обязательно) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- CORS / URL-адреса (обязательно в проде) ---
# CSV-список разрешённых origin фронтенда. Localhost-адреса добавляются автоматически.
ALLOWED_ORIGINS=https://planalitycai.vercel.app
FRONTEND_URL=https://planalitycai.vercel.app
APP_URL=https://planalitycai.vercel.app
API_PUBLIC_URL=https://planalityc-api.vercel.app

# --- Секреты приложения (обязательно) ---
# Случайные длинные строки. Сгенерировать: `openssl rand -hex 32`
SESSION_SECRET=change-me-openssl-rand-hex-32
INTEGRATION_SECRETS_KEY=change-me-openssl-rand-hex-32
CRON_SECRET=change-me-openssl-rand-hex-32

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=noreply@your-domain.kz

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Хранилище файлов (Vercel Blob; на своём сервере заменить на S3/диск) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# --- Мониторинг ошибок (опционально) ---
SENTRY_DSN=

# --- SMS-провайдер Nikita (опционально) ---
NIKITA_SMS_URL=
NIKITA_SMS_LOGIN=
NIKITA_SMS_PWD=
NIKITA_SMS_SENDER=
NIKITA_SMS_TEST=0                 # 1 — тестовый режим без реальной отправки

# --- Telegram-уведомления (опционально) ---
TELEGRAM_BOT_TOKEN=

# --- Vercel (выставляются платформой автоматически; на Hetzner НЕ нужны) ---
# VERCEL=1
# VERCEL_ENV=production
