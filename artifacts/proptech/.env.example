# ============================================================================
# Frontend (Vite) — пример переменных окружения.
# Скопируйте в `.env` и заполните. Префикс VITE_ обязателен — иначе переменная
# не попадёт в сборку. Файл `.env` в git НЕ коммитится.
# ============================================================================

# Базовый URL API. При переезде на свой сервер укажите свой домен API,
# напр. https://api.your-domain.kz
VITE_API_URL=https://planalityc-api.vercel.app
