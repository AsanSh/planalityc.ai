{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "node -e \"require('fs').accessSync('dist/index.mjs')\"",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "crons": [
    {
      "path": "/cron/sla-reminders",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/drizzle/migrations/**",
      "maxDuration": 120,
      "memory": 1024
    }
  }
}
