# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Server
PORT=3000
NODE_ENV=development

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Vercel Cron: Bearer-токен для /cron/* (задайте тот же CRON_SECRET в Vercel → planalityc-api)
CRON_SECRET=

# Planalityc.ai production URLs (override locally as needed)
FRONTEND_URL=https://planalitycai.vercel.app
API_PUBLIC_URL=https://planalityc-api.vercel.app

# Logging
LOG_LEVEL=info
