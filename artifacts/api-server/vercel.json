{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "crons": [
    {
      "path": "/cron/sla-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/cron/rental-lease-expiration",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/**,templates/**,drizzle/migrations/**}",
      "maxDuration": 120,
      "memory": 1024
    }
  }
}
